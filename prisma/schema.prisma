// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
 
}


model Property {
  id Int @id @default(autoincrement())
  title String 
  type PropertyType
  status PropertyStatus
  price Float
  
  lotArea Float?
  floorArea Float?
  bedRooms Int?
  bathRooms Int?
  parking Int?
  details String?
  slug String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  location Location?
  features Features[]
  amenity Amenity[]
  media Media[]
}


model Location{
  id Int @id @default(autoincrement())
  address String
  barangay String
  city String
  province String
  country String

  region String?
  zipCode String?
  coordinates Coordinate?
  boundaries Json?

  propertyId Int @unique
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

}


model Coordinate{
  id Int @id @default(autoincrement())
  lat Float
  lng Float

  locationId Int @unique
  location Location @relation(fields: [locationId] , references: [id], onDelete: Cascade)
}
model Features{
  id Int @id  @default(autoincrement())
  name String
  key String @unique

  properties Property[]
}

model Amenity{
  id Int @id @default(autoincrement())
  name String
  key String @unique

  properties Property[]

}
model Media{
  id Int @id @default(autoincrement())
  type MediaType
  url String
  isPrimary Boolean @default(false)
  /// Cloudinary `public_id` — used to delete/replace assets in Cloudinary
  cloudinaryPublicId String?
  propertyId Int 
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum PropertyType{
  LOT
  HOUSE_AND_LOT
  CONDO
  COMMERCIAL
}

enum PropertyStatus{
  AVAILABLE
  SOLD
  RESERVED
}



enum MediaType{
  IMAGE
  VIDEO
}

