# Backend Environment Variables Template
# Do NOT place real secrets in this file. It is safely committed to source control.
# Copy this file to '.env' and fill in the values on new machines.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ilocos_sur_property_db?schema=public"
PORT=3000
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# When true, Docker entrypoint runs `prisma db seed` after migrate (clears tables; uploads mock images to Cloudinary when keys are set).
SEED_ON_START=false