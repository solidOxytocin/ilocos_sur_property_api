# Backend Environment Variables Template
# Do NOT place real secrets in this file. It is safely committed to source control.
# Copy this file to '.env' and fill in the values on new machines.

# --- Postgres (used by docker-compose.postgres.yml; password must match DATABASE_URL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_DB=ilocos_sur_property_db

# Prisma: use `postgres` as host when the API runs in Docker; use `localhost` when running `npm run dev` on the host.
DATABASE_URL="postgresql://postgres:change_me_local_password@postgres:5432/ilocos_sur_property_db?schema=public"
DATABASE_URL_LOCAL="postgresql://postgres:change_me_local_password@localhost:5432/ilocos_sur_property_db?schema=public"

PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
ADMIN_JWT_SECRET=replace_with_a_long_random_secret
ADMIN_JWT_EXPIRES_IN=12h

# Optional bootstrap admin account (used to create an initial DB admin user when table is empty).
# Leave blank after first successful bootstrap if you don't want startup seeding behavior.
ADMIN_BOOTSTRAP_USERNAME=change_me
ADMIN_BOOTSTRAP_PASSWORD=change_me_once

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# When true, Docker entrypoint runs `prisma db seed` after migrate (clears tables; uploads mock images to Cloudinary when keys are set).
SEED_ON_START=false
